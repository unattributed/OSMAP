# Example OpenBSD env file for the local mailbox helper runtime.
# Intended installation target: /etc/osmap/osmap-mailbox-helper.env

OSMAP_RUN_MODE=mailbox-helper
OSMAP_ENV=production
OSMAP_LISTEN_ADDR=127.0.0.1:8080
OSMAP_DOVEADM_AUTH_SOCKET_PATH=/var/run/osmap-auth
OSMAP_TRUSTED_WEB_RUNTIME_UID=1001
OSMAP_DOVEADM_USERDB_SOCKET_PATH=/var/run/osmap-userdb
OSMAP_MAILBOX_HELPER_SOCKET_PATH=/var/lib/osmap-helper/run/mailbox-helper.sock
OSMAP_STATE_DIR=/var/lib/osmap-helper
OSMAP_RUNTIME_DIR=/var/lib/osmap-helper/run
OSMAP_SESSION_DIR=/var/lib/osmap-helper/sessions
OSMAP_SETTINGS_DIR=/var/lib/osmap-helper/settings
OSMAP_AUDIT_DIR=/var/lib/osmap-helper/audit
OSMAP_STDERR_LOG_PATH=/var/lib/osmap-helper/audit/mailbox-helper.log
OSMAP_CACHE_DIR=/var/lib/osmap-helper/cache
OSMAP_TOTP_SECRET_DIR=/var/lib/osmap-helper/secrets/totp
OSMAP_LOG_LEVEL=info
OSMAP_LOG_FORMAT=text
OSMAP_HTTP_MAX_CONCURRENT_CONNECTIONS=16
OSMAP_SESSION_LIFETIME_SECS=43200
OSMAP_TOTP_ALLOWED_SKEW_STEPS=1
OSMAP_LOGIN_THROTTLE_MAX_FAILURES=5
OSMAP_LOGIN_THROTTLE_REMOTE_MAX_FAILURES=12
OSMAP_LOGIN_THROTTLE_WINDOW_SECS=300
OSMAP_LOGIN_THROTTLE_LOCKOUT_SECS=900
OSMAP_SUBMISSION_THROTTLE_MAX_SUBMISSIONS=10
OSMAP_SUBMISSION_THROTTLE_REMOTE_MAX_SUBMISSIONS=25
OSMAP_SUBMISSION_THROTTLE_WINDOW_SECS=300
OSMAP_SUBMISSION_THROTTLE_LOCKOUT_SECS=900
OSMAP_MESSAGE_MOVE_THROTTLE_MAX_MOVES=20
OSMAP_MESSAGE_MOVE_THROTTLE_REMOTE_MAX_MOVES=60
OSMAP_MESSAGE_MOVE_THROTTLE_WINDOW_SECS=300
OSMAP_MESSAGE_MOVE_THROTTLE_LOCKOUT_SECS=900
OSMAP_OPENBSD_CONFINEMENT_MODE=enforce
