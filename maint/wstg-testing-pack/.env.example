# Core target settings
SCHEME=https
HOSTNAME=mail.example.com
EMAIL=user@example.com

# Output location
OUT_ROOT=$HOME/webmail-wstg

# Core route overrides, change only if your target uses different paths
LOGIN_PATH=/login
LOGOUT_PATH=/logout
SETTINGS_PATH=/settings
SESSIONS_PATH=/sessions
MAILBOXES_PATH=/mailboxes
COMPOSE_PATH=/compose
SEND_PATH=/send
SEARCH_PATH=/search
MESSAGE_VIEW_PATH=/message
MESSAGE_MOVE_PATH=/message/move
MESSAGES_ARCHIVE_PATH=/messages/archive
ATTACHMENT_PATH=/attachment

# Default object values for authenticated tests
DEFAULT_MAILBOX=INBOX
DEFAULT_MESSAGE_UID=156
DEFAULT_ATTACHMENT_PART=1.2
DEFAULT_ARCHIVE_MAILBOX=Junk
SEARCH_QUERY=INBOX
INVALID_EMAIL=nobody@@invalid.invalid

# Attacker-controlled placeholder values used by some client-side and header tests
ATTACKER_URL=https://attacker.invalid/wstg

# Timing and loop defaults
THROTTLE_ATTEMPTS=6
COOLDOWN_SECONDS=60
SHORT_SLEEP_SECONDS=1
SESSION_PROBE_COUNT=10
SESSION_PROBE_INTERVAL_SECONDS=120
LONG_IDLE_SECONDS=1800
HTTP_ALT_PORTS=80 8080

# Common websocket probe paths
WEBSOCKET_PATHS=/ws /socket /websocket /notifications /live /api/ws /sockjs /socket.io/

# Optional, leave blank to be prompted interactively
TEST_PASSWORD=
TEST_TOTP_CODE=
