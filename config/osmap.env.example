# OSMAP example configuration for local and staging bootstrap work.
# Copy this into an operator-managed environment file or service definition
# rather than editing the committed example in place.

# Supported run modes:
# - bootstrap
# - serve
# - mailbox-helper
OSMAP_RUN_MODE=bootstrap
OSMAP_ENV=development
OSMAP_LISTEN_ADDR=127.0.0.1:8080
# Optional explicit Dovecot auth socket path for least-privilege deployments.
# Leave unset unless the host provides a dedicated socket that the OSMAP runtime
# user is allowed to reach.
# OSMAP_DOVEADM_AUTH_SOCKET_PATH=/var/run/osmap/dovecot-auth
# Optional explicit Dovecot userdb socket path for mailbox and message helper
# lookups in least-privilege deployments.
# Leave unset unless the host provides a dedicated socket that the OSMAP runtime
# user is allowed to reach.
# OSMAP_DOVEADM_USERDB_SOCKET_PATH=/var/run/osmap/dovecot-userdb
# Optional mailbox-helper Unix socket path.
# Set this for the web-facing runtime when mailbox listing should go through the
# local mailbox helper, and set it for `OSMAP_RUN_MODE=mailbox-helper` when the
# helper should bind a specific socket path.
# OSMAP_MAILBOX_HELPER_SOCKET_PATH=/var/lib/osmap/run/mailbox-helper.sock
OSMAP_STATE_DIR=/var/lib/osmap
OSMAP_RUNTIME_DIR=/var/lib/osmap/run
OSMAP_SESSION_DIR=/var/lib/osmap/sessions
OSMAP_AUDIT_DIR=/var/lib/osmap/audit
OSMAP_CACHE_DIR=/var/lib/osmap/cache
OSMAP_TOTP_SECRET_DIR=/var/lib/osmap/secrets/totp
OSMAP_LOG_LEVEL=info
OSMAP_LOG_FORMAT=text
OSMAP_SESSION_LIFETIME_SECS=43200
OSMAP_TOTP_ALLOWED_SKEW_STEPS=1
# Application-layer login throttling for the browser auth path.
OSMAP_LOGIN_THROTTLE_MAX_FAILURES=5
OSMAP_LOGIN_THROTTLE_WINDOW_SECS=300
OSMAP_LOGIN_THROTTLE_LOCKOUT_SECS=900
OSMAP_OPENBSD_CONFINEMENT_MODE=disabled
